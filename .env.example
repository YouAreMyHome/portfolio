# EmailJS Configuration
# Đăng ký tại https://www.emailjs.com/ → lấy 3 giá trị dưới đây

# Service ID (Email Services tab)
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Template ID (Email Templates tab)
# Template cần có các variables: {{from_name}}, {{from_email}}, {{message}}, {{to_email}}
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx

# Public Key (Account → API Keys)
VITE_EMAILJS_USER_ID=xxxxxxxxxxxxxxxxxxxxxx
